{
  "name": "avelin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "compile": "turbo compile",
    "dev": "turbo dev --concurrency=15",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:push": "turbo run db:push",
    "ui:add": "turbo run ui:add",
    "release": "release-it minor"
  },
  "devDependencies": {
    "prettier": "catalog:",
    "release-it": "^17.10.0",
    "release-it-pnpm": "^4.6.3",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@9.12.2",
  "engines": {
    "node": ">=20"
  }
}
